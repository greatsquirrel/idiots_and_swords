  "LuaScript": "-- ============================================\n-- ГЛОБАЛЬНЫЙ СКРИПТ — Medieval Duel\n-- Только логика, без UI\n-- ============================================\n\n-- Состояние игры (доступно из Controller)\ngameState = {\n    phase = \"setup\",\n    round = 0,\n    currentPlayer = 1,\n    players = {}\n}\n\n-- ============================================\n-- ИНИЦИАЛИЗАЦИЯ\n-- ============================================\n\nfunction onLoad(script_state)\n    if script_state and script_state ~= \"\" then\n        local state = JSON.decode(script_state)\n        if state then\n            gameState = state\n        end\n    end\n    broadcastToAll(\"=== Medieval Duel загружен ===\")\nend\n\nfunction onSave()\n    return JSON.encode(gameState)\nend\n\n-- ============================================\n-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ\n-- ============================================\n\nfunction getPlayerCount()\n    return #getSeatedPlayers()\nend\n\nfunction getPlayerState(color)\n    return gameState.players[color]\nend\n\nfunction isAttack(cardName)\n    local attacks = {\"Удар\", \"Сокрушение\", \"Чары\", \"Укол\", \"Казнь\", \"Подсечка\", \"Комбо\", \"Укус\", \"Удар Грааля\", \"Подчинение\"}\n    for _, name in ipairs(attacks) do\n        if name == cardName then return true end\n    end\n    return false\nend\n\nfunction isDefense(cardName)\n    local defenses = {\"Блок\", \"Парирование\", \"Концентрация\", \"Барьер\", \"Уход в тень\"}\n    for _, name in ipairs(defenses) do\n        if name == cardName then return true end\n    end\n    return false\nend\n\nfunction isTechnique(cardName)\n    local techniques = {\"Уклонение\", \"Финт\", \"Отход\", \"Подлость\", \"Допинг\", \"Вспышка\", \"Насмешка\",\n                        \"Милость божья\", \"Шторм\"}\n    for _, name in ipairs(techniques) do\n        if name == cardName then return true end\n    end\n    return false\nend\n",
  "LuaScriptState": ""
}